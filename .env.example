# =============================================
# BlogOS — Variables de entorno
# Copia este archivo a .env.local y completa
# =============================================

# ── IA Principal ─────────────────────────────
# Obtener en: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── IA Alternativas (gratuitas) ──────────────
# Groq — ultra-rápido, tier gratuito: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini — 15 req/min gratis: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── SEO ──────────────────────────────────────
# Serper (Google real) — 2,500/mes gratis: https://serper.dev
SERPER_API_KEY=

# ── Noticias ─────────────────────────────────
# NewsAPI — 100 req/día gratis: https://newsapi.org/register
NEWSAPI_KEY=

# ── Proxy local (opcional) ───────────────────
# URL del túnel Cloudflare al servidor local
# Ej: https://random-words.trycloudflare.com
PROXY_TARGET_URL=
